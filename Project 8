];

const INITIAL_BOOKINGS = [
  { id: 'b1', customerId: 'u1', serviceId: 's1', providerId: 'u2', date: '2026-05-10', time: '10:00 AM', status: 'pending', address: '123 Main St' },
  { id: 'b2', customerId: 'u1', serviceId: 's3', providerId: 'u3', date: '2026-05-12', time: '02:00 PM', status: 'accepted', address: '123 Main St' },
];

// --- CONTEXT (Simulating Backend API & State Management) ---
const AppContext = createContext();

const AppProvider = ({ children }) => {
  const [users, setUsers] = useState(INITIAL_USERS);
  const [services, setServices] = useState(INITIAL_SERVICES);
  const [bookings, setBookings] = useState(INITIAL_BOOKINGS);
  const [currentUser, setCurrentUser] = useState(null);
  const [darkMode, setDarkMode] = useState(false);

  // Auth APIs
  const login = (email, password) => {
    const user = users.find(u => u.email === email && u.password === password);
    if (user) {
      setCurrentUser(user);
      return { success: true };
    }
    return { success: false, message: 'Invalid credentials' };
  };

  const signup = (userData) => {
    if (users.find(u => u.email === userData.email)) {
      return { success: false, message: 'Email already exists' };
    }
    const newUser = { ...userData, id: `u${Date.now()}` };
    setUsers([...users, newUser]);
    setCurrentUser(newUser);
    return { success: true };
  };

  const logout = () => setCurrentUser(null);

  // Service APIs
  const addService = (serviceData) => {
    const newService = { ...serviceData, id: `s${Date.now()}`, providerId: currentUser.id, rating: 0, reviews: 0 };
    setServices([...services, newService]);
  };

  const deleteService = (id) => setServices(services.filter(s => s.id !== id));

  // Booking APIs
  const createBooking = (bookingData) => {
    const newBooking = { ...bookingData, id: `b${Date.now()}`, customerId: currentUser.id, status: 'pending' };
    setBookings([...bookings, newBooking]);
    return { success: true };
  };

  const updateBookingStatus = (id, status) => {
    setBookings(bookings.map(b => b.id === id ? { ...b, status } : b));
  };

  const toggleDarkMode = () => setDarkMode(!darkMode);

  return (
    <AppContext.Provider value={{
      users, services, bookings, currentUser, darkMode,
      login, signup, logout, addService, deleteService, createBooking, updateBookingStatus, toggleDarkMode
    }}>
      {children}
    </AppContext.Provider>
  );
};

export const useAppContext = () => useContext(AppContext);

