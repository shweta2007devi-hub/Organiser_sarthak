const AppContent = () => {
  const { darkMode } = useAppContext();
  const [currentRoute, setCurrentRoute] = useState('home');
  const [routeParams, setRouteParams] = useState({});

  const navigate = (route, params = {}) => {
    setCurrentRoute(route);
    setRouteParams(params);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const renderView = () => {
    switch (currentRoute) {
      case 'home': return <Home navigate={navigate} />;
      case 'auth': return <Auth navigate={navigate} />;
      case 'services': return <ServicesList navigate={navigate} searchParams={routeParams} />;
      case 'service_detail': return <ServiceDetail navigate={navigate} serviceId={routeParams.id} />;
      case 'booking': return <BookingPage navigate={navigate} serviceId={routeParams.serviceId} />;
      case 'dashboard_customer': return <CustomerDashboard navigate={navigate} />;
      case 'dashboard_provider': return <ProviderDashboard navigate={navigate} />;
      case 'dashboard_admin': return <AdminDashboard navigate={navigate} />;
      case 'about': return <About />;
      case 'contact': return <Contact />;
      default: return <Home navigate={navigate} />;
    }
  };

  return (
    <div className={darkMode ? 'dark' : ''}>
      <div className="min-h-screen flex flex-col bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300 font-sans">
        <Navbar navigate={navigate} currentRoute={currentRoute} />
        <div className="flex-grow">
          {renderView()}
        </div>
        <Footer />
      </div>
    </div>
  );
};

export default function App() {
  return (
    <AppProvider>
      <AppContent />
    </AppProvider>
  );
}
