const CustomerDashboard = ({ navigate }) => {
  const { bookings, services, currentUser } = useAppContext();
  const myBookings = bookings.filter(b => b.customerId === currentUser.id);

  const getStatusBadge = (status) => {
    switch(status) {
      case 'pending': return <Badge type="warning">Pending</Badge>;
      case 'accepted': return <Badge type="success">Accepted</Badge>;
      case 'rejected': return <Badge type="danger">Rejected</Badge>;
      case 'completed': return <Badge type="blue">Completed</Badge>;
      default: return <Badge>{status}</Badge>;
    }
  };

  return (
    <DashboardLayout title="My Bookings" navigate={navigate}>
      {myBookings.length === 0 ? (
        <div className="bg-white dark:bg-gray-800 p-12 rounded-2xl text-center border border-gray-100 dark:border-gray-700">
          <Calendar className="w-12 h-12 text-gray-400 mx-auto mb-4" />
          <h3 className="text-lg font-medium text-gray-900 dark:text-white mb-2">No bookings yet</h3>
          <Button onClick={() => navigate('services')}>Explore Services</Button>
        </div>
      ) : (
        <div className="space-y-4">
          {myBookings.map(booking => {
            const service = services.find(s => s.id === booking.serviceId);
            return (
              <div key={booking.id} className="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 flex flex-col md:flex-row items-center justify-between gap-4">
                <div className="flex items-center gap-4">
                   <div className="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-xl flex items-center justify-center">
                     <Wrench className="text-gray-500" />
                   </div>
                   <div>
                     <h4 className="font-bold text-gray-900 dark:text-white">{service?.title || 'Unknown Service'}</h4>
                     <p className="text-sm text-gray-500 flex items-center gap-2 mt-1">
                        <Calendar className="w-3 h-3" /> {booking.date} at {booking.time}
                     </p>
                   </div>
                </div>
                <div className="flex items-center gap-4 w-full md:w-auto justify-between md:justify-end">
                   {getStatusBadge(booking.status)}
                   <Button variant="outline" size="sm" onClick={() => navigate('service_detail', { id: booking.serviceId })}>View</Button>
                </div>
              </div>
            )
          })}
        </div>
      )}
    </DashboardLayout>
  );
};

const ProviderDashboard = ({ navigate }) => {
  const { bookings, services, currentUser, updateBookingStatus, addService } = useAppContext();
  const [activeTab, setActiveTab] = useState('requests');
  const [showAddForm, setShowAddForm] = useState(false);
  const [newService, setNewService] = useState({ title: '', category: 'Plumber', price: '', description: '', location: '' });

  const myServices = services.filter(s => s.providerId === currentUser.id);
  const myRequests = bookings.filter(b => b.providerId === currentUser.id);

  const handleAddService = (e) => {
    e.preventDefault();
    addService({ ...newService, price: Number(newService.price) });
    setShowAddForm(false);
    setNewService({ title: '', category: 'Plumber', price: '', description: '', location: '' });
  };

  return (
    <DashboardLayout title="Provider Dashboard" navigate={navigate}>
      <div className="flex border-b border-gray-200 dark:border-gray-700 mb-6">
        <button 
          className={`py-3 px-6 font-medium border-b-2 transition-colors ${activeTab === 'requests' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'}`}
          onClick={() => setActiveTab('requests')}
        >Booking Requests</button>
        <button 
          className={`py-3 px-6 font-medium border-b-2 transition-colors ${activeTab === 'services' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'}`}
          onClick={() => setActiveTab('services')}
        >My Services</button>
      </div>

      {activeTab === 'requests' && (
        <div className="space-y-4">
          {myRequests.length === 0 && <p className="text-gray-500">No booking requests yet.</p>}
          {myRequests.map(req => {
            const service = services.find(s => s.id === req.serviceId);
            return (
              <div key={req.id} className="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div className="flex flex-col md:flex-row justify-between gap-4 mb-4">
                  <div>
                    <Badge type="warning" className="mb-2">New Request</Badge>
                    <h4 className="font-bold text-lg text-gray-900 dark:text-white">{service?.title}</h4>
                    <p className="text-gray-600 dark:text-gray-400 text-sm mt-1">Requested for: <span className="font-medium text-gray-900 dark:text-white">{req.date} at {req.time}</span></p>
                    <p className="text-gray-600 dark:text-gray-400 text-sm">Address: {req.address}</p>
                  </div>
                  <div className="text-right">
                    <div className="text-xl font-bold text-gray-900 dark:text-white">${service?.price}</div>
                  </div>
                </div>
                {req.status === 'pending' ? (
                  <div className="flex gap-3 mt-4 border-t border-gray-100 dark:border-gray-700 pt-4">
                    <Button variant="success" className="flex-1" onClick={() => updateBookingStatus(req.id, 'accepted')}>Accept</Button>
                    <Button variant="danger" className="flex-1" onClick={() => updateBookingStatus(req.id, 'rejected')}>Reject</Button>
                  </div>
                ) : (
                  <div className="mt-4 border-t border-gray-100 dark:border-gray-700 pt-4 text-sm font-medium">
                    Status: <span className={req.status === 'accepted' ? 'text-green-500' : 'text-red-500'}>{req.status.toUpperCase()}</span>
                  </div>
                )}
              </div>
            )
          })}
        </div>
      )}

      {activeTab === 'services' && (
        <div>
          <div className="flex justify-between items-center mb-6">
            <h3 className="text-xl font-bold text-gray-900 dark:text-white">Active Listings</h3>
            <Button onClick={() => setShowAddForm(!showAddForm)}><Plus className="w-4 h-4 mr-2"/> Add New Service</Button>
          </div>

          {showAddForm && (
            <form onSubmit={handleAddService} className="bg-blue-50 dark:bg-blue-900/10 p-6 rounded-2xl mb-8 border border-blue-100 dark:border-blue-900/30 space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <Input label="Title" required value={newService.title} onChange={e => setNewService({...newService, title: e.target.value})} />
                <div className="flex flex-col gap-1">
                  <label className="text-sm font-medium text-gray-700 dark:text-gray-300">Category</label>
                  <select 
                    className="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                    value={newService.category} onChange={e => setNewService({...newService, category: e.target.value})}
                  >
                    <option>Plumber</option><option>Electrician</option><option>Tutor</option><option>Delivery</option>
                  </select>
                </div>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <Input type="number" label="Price ($)" required value={newService.price} onChange={e => setNewService({...newService, price: e.target.value})} />
                <Input label="Service Area / Location" required value={newService.location} onChange={e => setNewService({...newService, location: e.target.value})} />
              </div>
              <Input label="Description" required value={newService.description} onChange={e => setNewService({...newService, description: e.target.value})} />
              <div className="flex gap-3 justify-end">
                <Button type="button" variant="ghost" onClick={() => setShowAddForm(false)}>Cancel</Button>
                <Button type="submit">Save Service</Button>
              </div>
            </form>
          )}

          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            {myServices.map(service => (
              <div key={service.id} className="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 flex justify-between items-center">
                <div>
                  <Badge type="blue" className="mb-2 inline-block">{service.category}</Badge>
                  <h4 className="font-bold text-gray-900 dark:text-white">{service.title}</h4>
                  <p className="text-gray-500 text-sm mt-1">${service.price} • {service.location}</p>
                </div>
                <Button variant="outline" size="sm" onClick={() => navigate('service_detail', { id: service.id })}>View</Button>
              </div>
            ))}
          </div>
        </div>
      )}
    </DashboardLayout>
  );
};

