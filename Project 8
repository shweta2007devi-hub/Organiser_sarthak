      result = result.filter(s => s.category === filterCat);
    }
    if (searchParams?.search) {
      const lowerSearch = searchParams.search.toLowerCase();
      result = result.filter(s => s.title.toLowerCase().includes(lowerSearch) || s.description.toLowerCase().includes(lowerSearch));
    }
