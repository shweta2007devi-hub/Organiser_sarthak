                  <input 
                    type="radio" 
                    name="category" 
                    className="w-4 h-4 text-blue-600 focus:ring-blue-500 border-gray-300"
                    checked={filterCat === cat}
                    onChange={() => setFilterCat(cat)}
                  />
                  <span className="text-gray-700 dark:text-gray-300">{cat}</span>
                </label>
              ))}
