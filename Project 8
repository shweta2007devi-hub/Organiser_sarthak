  if (!service) return null;

  const handleBook = (e) => {
    e.preventDefault();
    createBooking({ serviceId: service.id, providerId: service.providerId, date, time, address });
    setIsSuccess(true);
  };

  if (isSuccess) {
    return (
      <div className="max-w-md mx-auto px-4 py-20 text-center">
